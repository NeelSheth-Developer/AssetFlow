PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Use long, different random strings in production.
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-at-least-32-random-characters
OTP_SECRET=replace-with-another-at-least-32-random-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Create a Web OAuth client in Google Cloud Console.
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Keep the Resend key private. onboarding@resend.dev is for testing with your
# own Resend account email; use an address on your verified domain in production.
RESEND_API_KEY=re_replace_with_a_new_key
EMAIL_FROM=Your App <onboarding@resend.dev>

# Gmail SMTP (Nodemailer) — preferred sender; can deliver to ANY email.
# Create an App Password at myaccount.google.com/apppasswords (needs 2FA on).
APP_NAME=Your App
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=16-char-app-password

# Gemini — create a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Cloudinary — console.cloudinary.com/app/settings/api-keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
