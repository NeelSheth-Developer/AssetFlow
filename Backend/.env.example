PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# openssl rand -hex 32 — use a long random string in production.
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Frontend origin(s) for CORS with credentials. Comma-separate multiple origins.
CLIENT_URL=http://localhost:5173

APP_NAME=AssetFlow

# Brevo transactional email over HTTPS (works on Railway Free/Hobby).
# Verify BREVO_SENDER_EMAIL in the Brevo dashboard before sending.
BREVO_API_KEY=xkeysib-replace-with-your-private-api-key
BREVO_SENDER_EMAIL=your-verified-sender@example.com
BREVO_SENDER_NAME=AssetFlow
