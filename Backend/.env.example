PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# openssl rand -hex 32 — use a long random string in production.
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Frontend origin(s) for CORS with credentials. Comma-separate multiple origins.
CLIENT_URL=http://localhost:5173

APP_NAME=AssetFlow

# Gmail SMTP (Nodemailer) — preferred sender; can deliver to ANY email.
# Create an App Password at myaccount.google.com/apppasswords (needs 2FA on).
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=16-char-app-password

# Resend — fallback sender if Gmail SMTP is not configured or fails.
RESEND_API_KEY=re_replace_with_a_new_key
EMAIL_FROM=AssetFlow <onboarding@resend.dev>
