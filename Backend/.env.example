PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# openssl rand -hex 32 — use a long random string in production.
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Frontend origin(s) for CORS with credentials. Comma-separate multiple origins.
CLIENT_URL=http://localhost:5173

APP_NAME=AssetFlow

# SMTP (Nodemailer) — the only email sender; delivers to ANY address.
#
# Option A: Gmail (works locally; BLOCKED on Railway/Render free tiers).
# Create an App Password at myaccount.google.com/apppasswords (needs 2FA on).
# Leave SMTP_HOST/SMTP_PORT unset — they default to smtp.gmail.com:465.
MAIL_USER=your-gmail@gmail.com
MAIL_PASS=16-char-app-password
#
# Option B: Brevo relay on port 2525 (works on Railway/Render free tiers).
# Get credentials at app.brevo.com → Settings → SMTP & API → SMTP.
# MAIL_USER is the Brevo SMTP login (looks like 8a2f4b001@smtp-brevo.com),
# MAIL_PASS is the SMTP key, and MAIL_FROM must be a verified sender.
#SMTP_HOST=smtp-relay.brevo.com
#SMTP_PORT=2525
#MAIL_FROM=your-verified-sender@gmail.com
